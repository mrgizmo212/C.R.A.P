# Server
# This tool is intended for local-only use and always binds to 127.0.0.1.
# Normal setup only needs a port.
PORT=8088

# Optional lightweight token required by POST /api/reviews.
# This is not full authentication. Leave blank for local-only use.
REVIEW_TOKEN=

# Upload limits
MAX_BODY_BYTES=83886080
MAX_IMAGES=200
MAX_IMAGES_PER_SECTION=4
MAX_IMAGE_BYTES=15728640

# Optional AI report generation.
# The app still saves reviews and writes a deterministic fallback report without this key.
AI_REPORT_ENABLED=true
CURSOR_API_KEY=
QA_CURSOR_MODEL=composer-2
AI_REPORT_TIMEOUT_SECONDS=180
